# Repo root — used by `docker compose` for build args (copy to `.env` on the server).
#
# Local Docker / dev default:
NEXT_PUBLIC_API_URL=http://localhost:8000
#
# Production (Cloudflare + /api prefix):
# NEXT_PUBLIC_API_URL=https://pricing.skumancer.io/api

# --- Service-specific examples (host / non-Compose dev) ---
#
#   backend/.env          — FastAPI + Celery when running on the host
#   frontend/.env.local   — Next.js when running `npm run dev` on the host
#
# Browser API URL must be reachable from the user's machine (not Docker internal names).
# Do NOT set NEXT_PUBLIC_API_URL=http://backend:8000
