# Backend — copy to `backend/.env` for local dev (uvicorn on the host).
# In Docker Compose, service `environment:` overrides these for containers.

APP_NAME=Price Monitor API
DEBUG=false

# API routes are always available at /health and /api/health (see app/main.py).
# Frontend production URL should include /api, e.g. NEXT_PUBLIC_API_URL=https://your-host/api
# API_PREFIX is optional legacy; routing does not depend on it.

# When false (default), scrapes update competitor_products.latest_* only — no new price_snapshots rows.
PRICE_HISTORY_ENABLED=false

# Local dev: Postgres/Redis on localhost (Docker publishes ports 5432 / 6379).
DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/pricing_monitor
REDIS_URL=redis://localhost:6379/0

# Optional Celery overrides (default: same as REDIS_URL).
# CELERY_BROKER_URL=redis://localhost:6379/0
# CELERY_RESULT_BACKEND=redis://localhost:6379/0

# Comma-separated browser origins (localhost vs 127.0.0.1 are different origins).
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:3001,http://127.0.0.1:3001

# --- Docker-only (do NOT use in backend/.env when running uvicorn on the host) ---
# DATABASE_URL=postgresql+psycopg2://postgres:postgres@postgres:5432/pricing_monitor
# REDIS_URL=redis://redis:6379/0
